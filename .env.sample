# HTTP port the server binds to (default: 8888)
PORT=8888

# Maximum number of events accepted in a single batch submission (default: 1000,
# must be >= 1). Batches larger than this are rejected with 400.
MAX_BATCH_EVENTS=1000

# Log verbosity filter (e.g. info, debug, countingsheep=debug)
RUST_LOG=info

# Log output format: unset/anything = compact human, "json" = structured JSON
RUST_LOG_FORMAT=

# --- Error tracking (PostHog) ---
# PostHog project API key. SECRET — set via the environment, never commit a real
# value. When unset/blank, error tracking is disabled and nothing is sent.
POSTHOG_API_KEY=
# Kill-switch (default: true). Set to false to disable capture even with a key.
POSTHOG_ENABLED=true
# Ingestion host/region. Unset = US cloud. Set the EU endpoint or a self-hosted
# URL as needed, e.g. https://eu.i.posthog.com
POSTHOG_HOST=

# NOTE: DEV_DOCKER / HEROKU (which switch the bind address to 0.0.0.0) are read
# from the real process environment, NOT from this file — setting them here has
# no effect, by design, so a stray .env can't expose the server externally.

# --- Kafka event publishing ---
# Kafka (required — the server will not start without KAFKA_BROKERS)
# Local dev: start the broker with `docker compose -f docker-compose.kafka.yml up -d`
KAFKA_BROKERS=localhost:9092
# Kafka topic to publish accepted usage events to (default: sheeps).
KAFKA_TOPIC=sheeps
# Optional Kafka settings (uncomment to override defaults):
# KAFKA_CLIENT_ID=countingsheep
# KAFKA_SECURITY_PROTOCOL=plaintext   # or ssl / sasl_ssl
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
